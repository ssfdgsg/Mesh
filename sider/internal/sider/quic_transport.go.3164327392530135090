package sider

import (
	"context"
	"crypto/tls"
	"crypto/x509"
	"fmt"
	"net"
	"os"
	"strings"
	"sync"
	"time"

	"github.com/quic-go/quic-go"
)

func (p *Proxy) dialUpstream(ctx context.Context, addr string) (net.Conn, error) {
	switch normalizeNetwork(p.upstreamNetwork) {
	case "", "tcp":
		d := net.Dialer{Timeout: p.dialTimeout}
		return d.DialContext(ctx, "tcp", addr)
	case "quic":
		dialCtx := ctx
		var cancel context.CancelFunc
		if p.dialTimeout > 0 {
			dialCtx, cancel = context.WithTimeout(ctx, p.dialTimeout)
			defer cancel()
		}
		tlsConf, err := buildQUICClientTLSConfig(addr, p.upstreamTLS)
		if err != nil {
			return nil, err
		}
		conn, err := quic.DialAddr(dialCtx, addr, tlsConf, &quic.Config{})
		if err != nil {
			return nil, err
		}
		stream, err := conn.OpenStreamSync(dialCtx)
		if err != nil {
			conn.CloseWithError(0, "")
			return nil, err
		}
		return newQUICStreamConn(conn, stream, true), nil
	default:
		return nil, fmt.Errorf("unknown upstream_network: %q", p.upstreamNetwork)
	}
}

type quicStreamConn struct {
	quic.Stream
	conn      quic.Connection
	closeConn bool

	closeOnce sync.Once
}

func newQUICStreamConn(conn quic.Connection, stream quic.Stream, closeConn bool) net.Conn {
	return &quicStreamConn{
		Stream:     stream,
		conn:       conn,
		closeConn:  closeConn,
		closeOnce:  sync.Once{},
	}
}

func (c *quicStreamConn) LocalAddr() net.Addr  { return c.conn.LocalAddr() }
func (c *quicStreamConn) RemoteAddr() net.Addr { return c.conn.RemoteAddr() }

func (c *quicStreamConn) Close() error {
	var streamErr error
	c.closeOnce.Do(func() {
		streamErr = c.Stream.Close()
		if c.closeConn {
			c.conn.CloseWithError(0, "")
		}
	})
	return streamErr
}

func (c *quicStreamConn) CloseWrite() error {
	return c.Stream.Close()
}

func (c *quicStreamConn) SetDeadline(t time.Time) error      { return c.Stream.SetDeadline(t) }
func (c *quicStreamConn) SetReadDeadline(t time.Time) error  { return c.Stream.SetReadDeadline(t) }
func (c *quicStreamConn) SetWriteDeadline(t time.Time) error { return c.Stream.SetWriteDeadline(t) }

func buildQUICClientTLSConfig(upstreamAddr string, cfg *TLSConfig) (*tls.Config, error) {
	if cfg == nil {
		return nil, fmt.Errorf("quic: upstream_tls is required")
	}
	alpn := cfg.ALPN
	if alpn == "" {
		alpn = defaultQUICALPN
	}

	serverName := cfg.ServerName
	if serverName == "" && !cfg.InsecureSkipVerify {
		host := upstreamHost(upstreamAddr)
		if host == "" {
			return nil, fmt.Errorf("quic: cannot infer server_name from upstream addr %q", upstreamAddr)
		}
		if net.ParseIP(host) != nil {
			return nil, fmt.Errorf("quic: upstream_tls.server_name is required when upstream host is ip: %q", upstreamAddr)
		}
		serverName = host
	}

	tlsConf := &tls.Config{
		InsecureSkipVerify: cfg.InsecureSkipVerify,
		ServerName:         serverName,
		NextProtos:         []string{alpn},
		MinVersion:         tls.VersionTLS13,
	}

	if cfg.RootCAFile != "" {
		pemBytes, err := os.ReadFile(cfg.RootCAFile)
		if err != nil {
			return nil, fmt.Errorf("quic: read root_ca_file: %w", err)
		}
		roots := x509.NewCertPool()
		if ok := roots.AppendCertsFromPEM(pemBytes); !ok {
			return nil, fmt.Errorf("quic: root_ca_file contains no certificates")
		}
		tlsConf.RootCAs = roots
	}

	// If ServerName is empty and verification is disabled, still provide a stable one
	// to avoid some TLS stacks rejecting empty SNI.
	if tlsConf.ServerName == "" {
		tlsConf.ServerName = "sider.invalid"
	}
	tlsConf.ServerName = strings.TrimSpace(tlsConf.ServerName)
	return tlsConf, nil
}

